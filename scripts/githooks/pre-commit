#!/bin/bash
# ═══════════════════════════════════════════════════════════
# pre-commit — 提交前强制检查
# 安装: cp scripts/githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# ═══════════════════════════════════════════════════════════
#
# 检查项:
#   1. Commit message 格式 (type(scope): description)
#   2. node -c 语法检查 (staged JS)
#   3. JSON 格式检查 (staged JSON)
#   4. 大文件拦截 (>50MB)
#   5. 敏感文件拦截 (.env, secrets)
#   6. 品牌硬编码检查
#   7. console.log 泄露
#   8. 文件编码 (UTF-8)

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

echo -e "${CYAN}[pre-commit] 执行提交前检查...${NC}"

FAILED=0

# ─── 0. Commit Message 格式检查 ─────────────────────────
echo ""
echo -e "${CYAN}━━ 0/8 Commit Message 格式 ━━${NC}"

COMMIT_MSG_FILE="$PROJECT_DIR/.git/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
  FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE" | sed 's/^#.*//' | tr -d '[:space:]')
  if [ -n "$FIRST_LINE" ]; then
    # Check format: type(scope): description
    if ! echo "$FIRST_LINE" | grep -qE '^(feat|fix|refactor|perf|style|docs|chore|ci|revert|test)\(.+\):.+'; then
      echo -e "  ${YELLOW}⚠ WARN${NC}  Commit message 不符合 <type>(<scope>): <desc> 格式"
      echo -e "  ${YELLOW}       当前: ${FIRST_LINE}${NC}"
      echo -e "  ${YELLOW}       建议: feat(nav): add mobile menu toggle${NC}"
    else
      echo -e "  ${GREEN}✓ Commit message 格式正确${NC}"
    fi

    # Check for forbidden messages
    FORBIDDEN=("WIP" "temp" "asdf" "fix stuff" "update" "changes" ".")
    for word in "${FORBIDDEN[@]}"; do
      if echo "$FIRST_LINE" | grep -qi "^$word$"; then
        echo -e "  ${RED}✗ ERR${NC}  Forbidden commit message: \"$word\""
        FAILED=1
      fi
    done
  fi
else
  echo -e "  ${YELLOW}⊘ 跳过（无 commit message file）${NC}"
fi

# ─── 1. 获取 staged 文件 ────────────────────────────────
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$' 2>/dev/null || true)
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM | grep '\.json$' 2>/dev/null | grep -v 'package-lock\|node_modules' || true)
STAGED_HTML=$(git diff --cached --name-only --diff-filter=ACM | grep '\.html$' 2>/dev/null || true)

# ─── 2. 大文件检查 ──────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 1/8 大文件检查 (>50MB) ━━${NC}"
LARGE_FILES=0
for f in $(git diff --cached --name-only); do
  if [ -f "$f" ]; then
    SIZE=$(wc -c < "$f" | tr -d ' ')
    if [ "$SIZE" -gt 52428800 ]; then
      echo -e "  ${RED}✗ ERR${NC}  $f (${SIZE} bytes > 50MB) — 使用 CDN 或 Git LFS"
      LARGE_FILES=1
      FAILED=1
    fi
  fi
done
if [ "$LARGE_FILES" -eq 0 ]; then
  echo -e "  ${GREEN}✓ 无大文件${NC}"
fi

# ─── 3. 敏感文件检查 ────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 2/8 敏感文件检查 ━━${NC}"
SECRET_FILES=0
for f in $(git diff --cached --name-only); do
  case "$f" in
    *.env|.env*|.env.*) 
      echo -e "  ${RED}✗ ERR${NC}  $f — .env 文件禁止提交"
      SECRET_FILES=1; FAILED=1 ;;
    *.pem|*.key|*.p12|*.pfx)
      echo -e "  ${RED}✗ ERR${NC}  $f — 证书/密钥文件禁止提交"
      SECRET_FILES=1; FAILED=1 ;;
  esac
done
# Check content for secrets
for f in $(git diff --cached --name-only --diff-filter=ACM); do
  if [ -f "$f" ]; then
    if grep -qiE '(password|secret|api_key|apikey|token|private_key)\s*[:=]\s*["\x27][^\s"'\'']{8,}' "$f" 2>/dev/null; then
      echo -e "  ${RED}✗ ERR${NC}  $f — 可能包含敏感信息（password/secret/api_key）"
      SECRET_FILES=1; FAILED=1
    fi
  fi
done
if [ "$SECRET_FILES" -eq 0 ]; then
  echo -e "  ${GREEN}✓ 无敏感文件${NC}"
fi

# ─── 4. JS 语法检查 ─────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 3/8 JS 语法检查 (node -c) ━━${NC}"
JS_FAIL=0
if [ -n "$STAGED_JS" ]; then
  for f in $STAGED_JS; do
    if [ -f "$f" ]; then
      if node -c "$f" 2>/dev/null; then
        echo -e "  ${GREEN}✓ $f${NC}"
      else
        echo -e "  ${RED}✗ 语法错误: $f${NC}"
        JS_FAIL=1
      fi
    fi
  done
else
  echo -e "  ${YELLOW}⊘ 无 JS 文件变更${NC}"
fi
if [ "$JS_FAIL" -ne 0 ]; then FAILED=1; fi

# ─── 5. JSON 格式检查 ───────────────────────────────────
echo ""
echo -e "${CYAN}━━ 4/8 JSON 格式检查 ━━${NC}"
JSON_FAIL=0
if [ -n "$STAGED_JSON" ]; then
  for f in $STAGED_JSON; do
    if [ -f "$f" ]; then
      if node -e "JSON.parse(require('fs').readFileSync('$f','utf8'))" 2>/dev/null; then
        echo -e "  ${GREEN}✓ $f${NC}"
      else
        echo -e "  ${RED}✗ JSON 格式错误: $f${NC}"
        JSON_FAIL=1
      fi
    fi
  done
else
  echo -e "  ${YELLOW}⊘ 无 JSON 文件变更${NC}"
fi
if [ "$JSON_FAIL" -ne 0 ]; then FAILED=1; fi

# ─── 6. 品牌硬编码检查 ─────────────────────────────────
echo ""
echo -e "${CYAN}━━ 5/8 品牌硬编码检查 ━━${NC}"
BRAND_FAIL=0
for f in $(git diff --cached --name-only --diff-filter=ACM '*.js'); do
  if [ -f "$f" ]; then
    # New #ec5b13 not in fallback context
    if grep -n '#ec5b13' "$f" | grep -v '||.*#ec5b13\|var.*_primary\|//\|*/' > /dev/null 2>&1; then
      echo -e "  ${RED}✗ $f — 新增硬编码品牌色 #ec5b13${NC}"
      BRAND_FAIL=1
    fi
    # console.log without guard
    if grep -n 'console\.\(log\|debug\|info\)' "$f" | grep -v '__DEVELOPMENT__\|//\|*/' > /dev/null 2>&1; then
      echo -e "  ${YELLOW}⚠ $f — console.log 未 guard${NC}"
    fi
  fi
done
if [ "$BRAND_FAIL" -ne 0 ]; then FAILED=1; fi
if [ "$BRAND_FAIL" -eq 0 ]; then
  echo -e "  ${GREEN}✓ 无品牌硬编码泄露${NC}"
fi

# ─── 7. HTML 标签检查 ──────────────────────────────────
echo ""
echo -e "${CYAN}━━ 6/8 HTML 标签检查 ━━${NC}"
HTML_FAIL=0
if [ -n "$STAGED_HTML" ]; then
  for f in $STAGED_HTML; do
    if [ -f "$f" ]; then
      # Check for unclosed void elements (simple regex)
      UNCLOSED=$(grep -cE '<(img|br|hr|input|meta|link)[^>]*(?<!/)>' "$f" 2>/dev/null || echo "0")
      if [ "$UNCLOSED" -gt 0 ]; then
        echo -e "  ${YELLOW}⚠ $f — $UNCLOSED unclosed void elements (self-close with />)${NC}"
      fi
    fi
  done
else
  echo -e "  ${YELLOW}⊘ 无 HTML 文件变更${NC}"
fi

# ─── 8. 编码检查 ────────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 7/8 文件编码检查 ━━${NC}"
ENCODING_FAIL=0
for f in $(git diff --cached --name-only --diff-filter=ACM); do
  if [ -f "$f" ]; then
    ENCODING=$(file -b --mime-encoding "$f" 2>/dev/null || echo "unknown")
    if echo "$ENCODING" | grep -qiE 'utf-8|us-ascii|ascii'; then
      : # OK
    else
      echo -e "  ${RED}✗ $f — encoding: $ENCODING (must be UTF-8)${NC}"
      ENCODING_FAIL=1
    fi
  fi
done
if [ "$ENCODING_FAIL" -ne 0 ]; then FAILED=1; fi
if [ "$ENCODING_FAIL" -eq 0 ]; then
  echo -e "  ${GREEN}✓ 所有文件 UTF-8 编码${NC}"
fi

# ─── Summary ──────────────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 8/8 项目 Lint ━━${NC}"
if command -v node &>/dev/null; then
  if node "$PROJECT_DIR/scripts/lint-code.js" --staged 2>/dev/null; then
    : # passed
  else
    echo -e "  ${YELLOW}⚠ lint-code.js 报告了问题（参见上方）${NC}"
  fi
else
  echo -e "  ${YELLOW}⊘ node 不可用，跳过 lint-code.js${NC}"
fi

# ─── Result ───────────────────────────────────────────────
echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}✗ pre-commit 检查失败！请修复后再提交。${NC}"
  echo -e "${YELLOW}跳过: git commit --no-verify（不推荐）${NC}"
  exit 1
else
  echo -e "${GREEN}✅ 所有检查通过，允许提交。${NC}"
  exit 0
fi
