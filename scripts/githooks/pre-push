#!/bin/bash
# ═══════════════════════════════════════════════════════════
# pre-push — 推送前强制检查
# 安装: cp scripts/githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# ═══════════════════════════════════════════════════════════
#
# 检查项:
#   1. 分支保护（禁止直推 master）
#   2. 禁止 force push master
#   3. 全量 JS 语法检查
#   4. 项目 Lint (lint-code.js)
#   5. 构建验证 (npm run build)

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

echo -e "${CYAN}[pre-push] 执行推送前检查...${NC}"

FAILED=0
SKIP_BUILD=0

# ─── 0. 分支保护 ────────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 1/5 分支保护 ━━${NC}"

REMOTE_BRANCH=$(git rev-parse --abbrev-ref @{push} 2>/dev/null | sed 's|.*/||' || echo "")
LOCAL_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Check if pushing to master/main
if [ "$REMOTE_BRANCH" = "master" ] || [ "$REMOTE_BRANCH" = "main" ]; then
  echo -e "  ${RED}✗ ERR${NC}  禁止直接 push 到 $REMOTE_BRANCH"
  echo -e "  ${RED}       请创建功能分支并提交 Pull Request${NC}"
  echo -e "  ${YELLOW}       快速创建: git checkout -b feat/your-feature && git push -u origin feat/your-feature${NC}"
  FAILED=1
else
  echo -e "  ${GREEN}✓ 推送到 $REMOTE_BRANCH (非保护分支)${NC}"
fi

# Check force push
IS_FORCE=0
while read -r line; do
  case "$line" in
    *force*|*delete*) IS_FORCE=1 ;;
  esac
done < <(git push --dry-run "$@" 2>&1 || true)

if [ "$IS_FORCE" -eq 1 ]; then
  if [ "$REMOTE_BRANCH" = "master" ] || [ "$REMOTE_BRANCH" = "main" ]; then
    echo -e "  ${RED}✗ ERR${NC}  绝对禁止 force push 到 $REMOTE_BRANCH"
    FAILED=1
  else
    echo -e "  ${YELLOW}⚠ WARN${NC}  force push 到 $REMOTE_BRANCH（确认无其他人在此分支工作）"
  fi
fi

# ─── 1. 全量 JS 语法检查 ────────────────────────────────
echo ""
echo -e "${CYAN}━━ 2/5 全量 JS 语法检查 (node -c) ━━${NC}"
JS_SYNTAX_FAIL=0
JS_COUNT=0
for f in $(find src/assets/js -name '*.js' -not -name '*.min.js'); do
  JS_COUNT=$((JS_COUNT + 1))
  if ! node -c "$f" 2>/dev/null; then
    echo -e "  ${RED}✗ $f${NC}"
    JS_SYNTAX_FAIL=1
  fi
done
if [ "$JS_SYNTAX_FAIL" -eq 0 ]; then
  echo -e "  ${GREEN}✓ $JS_COUNT files syntax OK${NC}"
else
  echo -e "  ${RED}✗ JS syntax errors found${NC}"
  FAILED=1
fi

# ─── 2. 项目 Lint ───────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 3/5 项目 Lint (lint-code.js) ━━${NC}"
if command -v node &>/dev/null && [ -f "$PROJECT_DIR/scripts/lint-code.js" ]; then
  if node "$PROJECT_DIR/scripts/lint-code.js" 2>/dev/null; then
    : # passed
  else
    echo -e "  ${YELLOW}⚠ lint-code.js 有警告/错误（参见上方）${NC}"
    # Warnings don't block push, errors do
    node "$PROJECT_DIR/scripts/lint-code.js" 2>/dev/null || FAILED=1
  fi
else
  echo -e "  ${YELLOW}⊘ lint-code.js 不可用，跳过${NC}"
fi

# ─── 3. site.config.js 语法 ─────────────────────────────
echo ""
echo -e "${CYAN}━━ 4/5 site.config.js 验证 ━━${NC}"
if [ -f "$PROJECT_DIR/site.config.js" ]; then
  if node -c "$PROJECT_DIR/site.config.js" 2>/dev/null; then
    # Verify it sets window.SITE_CONFIG
    if node -e "require('$PROJECT_DIR/site.config.js')" 2>/dev/null; then
      echo -e "  ${GREEN}✓ site.config.js OK${NC}"
    else
      echo -e "  ${YELLOW}⚠ site.config.js 加载可能有问题${NC}"
    fi
  else
    echo -e "  ${RED}✗ site.config.js 语法错误${NC}"
    FAILED=1
  fi
else
  echo -e "  ${RED}✗ site.config.js 不存在！${NC}"
  FAILED=1
fi

# ─── 4. 构建验证 ──────────────────────────────────────────
echo ""
echo -e "${CYAN}━━ 5/5 构建验证 ━━${NC}"
if [ "$SKIP_BUILD" -eq 1 ]; then
  echo -e "  ${YELLOW}⊘ 跳过（PR 模式）${NC}"
else
  if command -v node &>/dev/null && [ -f "$PROJECT_DIR/build.sh" ]; then
    BUILD_START=$(date +%s)
    if bash "$PROJECT_DIR/build.sh" > /dev/null 2>&1; then
      BUILD_END=$(date +%s)
      BUILD_TIME=$((BUILD_END - BUILD_START))

      # Verify key outputs
      if [ ! -f "$PROJECT_DIR/dist/site.config.js" ]; then
        echo -e "  ${RED}✗ dist/site.config.js 不存在！构建不完整${NC}"
        FAILED=1
      elif [ ! -f "$PROJECT_DIR/dist/index.html" ]; then
        echo -e "  ${RED}✗ dist/index.html 不存在！构建不完整${NC}"
        FAILED=1
      else
        echo -e "  ${GREEN}✓ 构建成功 (${BUILD_TIME}s)${NC}"
      fi
    else
      echo -e "  ${RED}✗ 构建失败！${NC}"
      FAILED=1
    fi
  else
    echo -e "  ${YELLOW}⊘ build.sh 不可用，跳过${NC}"
  fi
fi

# ─── Result ───────────────────────────────────────────────
echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}✗ pre-push 检查失败！请修复后再 push。${NC}"
  echo -e "${YELLOW}跳过检查使用 git push --no-verify（不推荐，仅紧急情况使用）${NC}"
  exit 1
else
  echo -e "${GREEN}✅ 所有检查通过，允许推送。${NC}"
  exit 0
fi
