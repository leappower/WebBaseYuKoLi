# ═══════════════════════════════════════════════════════
# KitchenYuKoLi / BrewYuKoLi — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────
node_modules/
.pnp/
.pnp.js
.pnp.cjs

# ─── Build outputs ────────────────────────────────
dist/
build/
out/

# ─── Cache & temp ─────────────────────────────────
.cache/
.tmp/
.parcel-cache/
.nyc_output/
coverage/
tmp/
temp/

# ─── Environment & secrets ────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ─────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── OS files ─────────────────────────────────────
.DS_Store
Thumbs.db
Icon?
ehthumbs.db
*.swp
*.swo
*~

# ─── IDEs ─────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ─── Secrets & certs ──────────────────────────────
*.pem
*.key
*.crt

# ─── Large media files (use CDN / Git LFS) ───────
# Video files > 50 MB must NOT be committed directly.
# Use Git LFS:  git lfs track "*.mp4"
# Or host externally and reference via URL.
*.mp4
*.mov
*.avi
*.mkv

# ─── OpenClaw internal ────────────────────────────
.openclaw-project
skill/.openclaw-project/
translate-quota.json

# ─── Playwright ───────────────────────────────────
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# ─── Misc / archive ───────────────────────────────
scripts/ci/
scripts/archive/
scripts/.archive/
.reference/
.githooks/

# Generated scripts
generate_hero_images.py
i18n_delta_fixed.py
scripts/regenerate_oem_images.py
scripts/run_i18n_translate.sh

# Temp directories
output/
products-original/
hero-original/

# Backups
zh-CN-ui.json.bak
