# BrewYuKoLi 开发环境 Docker 镜像
# 支持 HTTPS + 热更新

FROM node:18-alpine

# 设置工作目录
WORKDIR /app

# 安装系统依赖
RUN apk add --no-cache \
    git \
    curl \
    caddy \
    nodejs-npm \
    && npm install -g nodemon fswatch

# 复制 package.json 和 package-lock.json
COPY package*.json ./

# 安装依赖
RUN npm ci

# 复制源代码
COPY . .

# 构建开发环境
RUN npm run build:css

# 暴露端口
EXPOSE 3099 3443

# 设置环境变量
ENV NODE_ENV=development
ENV PORT=3099
ENV SSL_PORT=3443
ENV ENABLE_SSL=true

# 开发启动脚本
COPY devops/scripts/dev-server.sh /app/dev-server.sh
RUN chmod +x /app/dev-server.sh

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3099/health || exit 1

# 启动命令
CMD ["/app/dev-server.sh"]