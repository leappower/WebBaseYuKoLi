# ═══════════════════════════════════════
# BrewYuKoLi 环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ═══════════════════════════════════════

# ── 服务器配置 ──
PORT=3000
NODE_ENV=development

# ── 语言文件同步 ──
# deploy-lang-sync.js 使用的目标项目路径（可选）
# KITCHEN_YUKOLI_SERVER=../KitchenYuKoLiServer

# ── Google Analytics（可选） ──
# GTAG_ID=G-XXXXXXXXXX

# ── 开发调试 ──
# 启用详细日志（开发环境默认开启）
# DEBUG=true
